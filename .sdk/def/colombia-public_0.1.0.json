          "Country"
        ],
        "responses": {
          "200": {
            "description": "Successful response with Colombia information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Country"
                }
              }
            }
          },
          "404": {
            "description": "Country information not found"
